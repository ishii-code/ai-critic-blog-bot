# === LLM API ===
# Claude（記事生成 + カバー画像プロンプト生成）
ANTHROPIC_API_KEY=
# OpenAI（DALL-E 3 カバー画像生成）
OPENAI_API_KEY=

# === DB（Cloud SQL / PostgreSQL）===
# Cloud Run: Secret Manager の spm-dev-agent-database-url（unix socket 形式）から注入。
# ローカル検証: パブリック IP 直結 or cloud-sql-proxy 経由の 127.0.0.1。
DATABASE_URL=

# === カバー画像（GCS）===
GCS_BUCKET_NAME=vets-biz-aigen-apps-blog-images

# === ブログ表示 URL ===
BLOG_PUBLIC_URL=https://ai-blog-842623777962.asia-northeast1.run.app

# === 動作設定 ===
# dry_run … 記事生成まで（DB 書き込み・画像生成なし）
# draft   … published=false で下書き保存
# publish … published=true で公開保存 + カバー画像生成
RUN_MODE=dry_run
